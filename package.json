{
  "name": "mcp-agenda-tool",
  "version": "0.1.0",
  "description": "Mock MCP server for a medical booking agenda simulator",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "demo": "ts-node src/demo.ts",
    "mcp": "ts-node src/mcpServer.ts",
